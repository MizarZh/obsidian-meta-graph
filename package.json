{
	"name": "obsidian-meta-graph",
	"version": "1.0.1",
	"description": "Visualize and edit metadata-linked relationships between notes as an interactive graph.",
	"main": "main.js",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"typecheck": "tsc -noEmit -skipLibCheck && svelte-check --tsconfig ./tsconfig.json",
		"build": "pnpm typecheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"dependencies": {
		"3d-force-graph": "^1.80.0",
		"d3-force": "^3.0.0",
		"d3-hierarchy": "^3.1.2",
		"d3-scale": "^4.0.2",
		"elkjs": "^0.11.0",
		"graphology": "^0.26.0",
		"graphology-layout-forceatlas2": "^0.10.1",
		"sigma": "^3.0.2",
		"svelte": "^5.34.7",
		"three": "0.185.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/d3-force": "^3.0.10",
		"@types/d3-hierarchy": "^3.1.7",
		"@types/d3-scale": "^4.0.9",
		"@types/node": "^22.15.17",
		"@types/three": "^0.185.0",
		"esbuild": "0.25.5",
		"esbuild-svelte": "^0.9.3",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"prettier": "^3.9.4",
		"svelte-check": "^4.3.4",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^3.2.4"
	}
}
